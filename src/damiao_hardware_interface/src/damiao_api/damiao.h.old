//     MOS_OVERTEMPERATURE     = -15,
//     COIL_OVERTEMPERATURE    = -16,
//     COMMUNICATION_LOSS      = -17,
//     OVERLOAD                = -18,
//     SERIAL_READ             = -19,
//     MOTOR_NOT_FOUND         = -20,
//     MASTER_ID_NOT_FOUND     = -21,
//     UNKNOWN_CMD             = -22,
// };

