//     PORT_CONFIG_FAILED      = -3,
//     WAIT_TIMEOUT            = -4,
//     WAIT_SELECT_FAILED      = -5,
//     READ_FAILED             = -6,
//     WRONG_END_BYTE          = -7,
 
//     // Motor / CAN errors
//     RECEIVE_FAIL            = -10,
//     SEND_FAIL               = -11,
//     COMMUNICATION           = -12,
//     OVERVOLTAGE             = -13,
